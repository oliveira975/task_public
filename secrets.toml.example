# Copie este arquivo para .streamlit/secrets.toml e preencha com os dados
# do seu projeto Supabase (Project Settings > API).
SUPABASE_URL = "https://SEU-PROJETO.supabase.co"
SUPABASE_ANON_KEY = "sua-anon-key-aqui"

# Necessária só para a página Admin (criar contas, trocar senha,
# ativar/desativar). Fica em Project Settings > API > service_role.
# NUNCA exponha essa chave publicamente nem a coloque no frontend —
# ela dá acesso total ao seu projeto Supabase, ignorando o RLS.
SUPABASE_SERVICE_ROLE_KEY = "sua-service-role-key-aqui"

# E-mails (separados por vírgula) que podem acessar a página Admin.
ADMIN_EMAILS = "seu-email@empresa.com, outro-admin@empresa.com"
